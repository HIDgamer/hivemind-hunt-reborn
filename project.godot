[internationalization]

pseudolocalization/hdr_2d=true

[layer_names]

2d_physics/layer_1="World"
2d_physics/layer_2="Player"
2d_physics/layer_3="Objects"
2d_physics/layer_4="Enemies"

[memory]

limits/message_queue/max_size_mb=4096

[physics]

2d/run_on_separate_thread=true
common/physics_jitter_fix=2.0
2d/physics_engine="Rapier2D"
jolt_physics_3d/simulation/generate_all_kinematic_contacts=true
jolt_physics_3d/queries/use_enhanced_internal_edge_removal=true
jolt_physics_3d/queries/enable_ray_cast_face_index=true
common/physics_interpolation=true

[rendering]

textures/canvas_textures/default_texture_filter=0
lights_and_shadows/use_physical_light_units=true
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=5
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=5
2d/shadow_atlas/size=4096
textures/default_filters/use_nearest_mipmap_filter=true
textures/default_filters/anisotropic_filtering_level=4
viewport/hdr_2d=true
textures/decals/filter=4
textures/light_projectors/filter=4
limits/opengl/max_renderable_lights=256
limits/opengl/max_lights_per_object=500
environment/defaults/default_clear_color=Color(0.0032443097, 0.0032439607, 0.0061829584, 1)
lights_and_shadows/positional_shadow/atlas_quadrant_0_subdiv=3
lights_and_shadows/positional_shadow/atlas_quadrant_1_subdiv=4
lights_and_shadows/positional_shadow/atlas_quadrant_2_subdiv=5
lights_and_shadows/positional_shadow/atlas_quadrant_3_subdiv=6

[threading]

worker_pool/max_threads=1
