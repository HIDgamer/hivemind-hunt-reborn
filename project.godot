; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Hivemind-Hunt_Reborn"
run/main_scene="uid://cnw6i1v1qt1rh"
config/features=PackedStringArray("4.7", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

CheckpointManager="*res://Code/Systems/CheckpointManager.cs"
GameSettings="*res://Code/Systems/GameSettings.cs"
PauseMenu="*res://Scenes/UI/PauseMenu.tscn"
NetworkManager="*res://Code/Networking/NetworkManager.cs"

[dotnet]

project/assembly_name="Hivemind-Hunt_Reborn"

[file_customization]

folder_colors={
"res://Addons/": "red",
"res://Assets/": "orange",
"res://Code/": "gray",
"res://Scenes/": "blue",
"res://Sound/": "purple"
}

