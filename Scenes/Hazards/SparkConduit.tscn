# A gap of broken/exposed wiring — no fixture sprite, the light and particles
# ARE the visual. Deals light contact damage on a cooldown (see SparkHazard.cs)
# and periodically pops with a bright flash + particle burst + sound
# (FlickeringLight.cs, SparkBurst profile). A constant low crackle loops in
# the background so it reads as "actively arcing" even between bursts.
[node name="SparkConduit" type="Node2D"]
script = ExtResource("1_flicker")
Profile = 2
SparkIntervalMin = 2.0
SparkIntervalMax = 5.5
SparkFlashEnergyScale = 3.0
SparkSound = ExtResource("3_spark")

